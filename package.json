{
  "name": "manuscript-vault-manager",
  "version": "0.0.1",
  "description": "Manuscript Vault Manager — syncs Scrivener projects into Obsidian vaults",
  "main": "./out/main/index.js",
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "cross-env ELECTRON_RUN_AS_NODE= electron-vite dev",
    "start": "cross-env ELECTRON_RUN_AS_NODE= electron-vite preview",
    "build": "npm run typecheck && cross-env ELECTRON_RUN_AS_NODE= electron-vite build && electron-builder --win",
    "build:unpack": "npm run typecheck && cross-env ELECTRON_RUN_AS_NODE= electron-vite build && electron-builder --dir",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "fast-xml-parser": "^5.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^4.1.4"
  }
}
